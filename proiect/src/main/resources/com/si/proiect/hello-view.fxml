<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.si.proiect.HelloController" prefWidth="400">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!--adaugare algoritm-->
    <Label text="Adauga algoritm nou" style="-fx-font-weight: bold;"/>
    <GridPane hgap="10" vgap="10">
        <Label text="Nume:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="algNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Tip (Simetric/Asimetric):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="algTypeField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>
    <Button text="Salveaza algoritm" onAction="#onAddAlgorithmClick" maxWidth="Infinity"/>

    <Separator/>

    <!--adaugarea rezultatului-->
    <Label text="Adauga rezultat test" style="-fx-font-weight: bold;"/>
    <GridPane hgap="10" vgap="10">
        <Label text="Timp executie(ms):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="execTimeField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Alege algoritm:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="algComboBox" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>
    </GridPane>
    <Button text="Salveaza rezultat" onAction="#onAddResultClick" maxWidth="Infinity"/>

    <Label fx:id="statusLabel" text="Status: Gata" style="-fx-text-fill: blue;"/>
</VBox>