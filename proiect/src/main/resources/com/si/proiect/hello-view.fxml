<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.si.proiect.HelloController" prefWidth="450">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="1. Adauga algoritm nou" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label text="Nume (ex: AES):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="algNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Tip (Simetric/Asimetric):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="algTypeField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>
    <Button text="Salveaza algoritm in DB" onAction="#onAddAlgorithmClick" maxWidth="Infinity"/>

    <Separator/>

    <Label text="2. Executa Criptare" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label text="Alege algoritmul:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="algComboBox" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity" promptText="Selecteaza..."/>
    </GridPane>
    <Button text="Testeaza Criptarea (OpenSSL vs JCA)" onAction="#onEncryptButtonClick" maxWidth="Infinity"/>

    <Separator/>

    <Label text="3. Salveaza performanta" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label text="Timp executie (ms):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="execTimeField" GridPane.rowIndex="0" GridPane.columnIndex="1" editable="false" />
    </GridPane>
    <Button text="Salveaza rezultat in DB" onAction="#onAddResultClick" maxWidth="Infinity"/>

    <Separator/>

    <Label text="Status" style="-fx-text-fill: gray;"/>
    <Separator/>
    <Button text="Mod Debug: Obtinere Chei DB" onAction="#onDebugKeysClick" maxWidth="Infinity" style="-fx-background-color: #ffcc00; -fx-font-weight: bold;"/>
    <Label fx:id="statusLabel" text="Asteptare actiune..." style="-fx-text-fill: blue; -fx-font-weight: bold;" wrapText="true" textAlignment="CENTER"/>
</VBox>